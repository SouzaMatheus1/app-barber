generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model TipoEmpresa {
  id                Int                @id @default(autoincrement())
  descricao         String             @unique
  empresas          Empresa[]
  tipoEmpresaAtivos TipoEmpresaAtivo[]

  @@map("TipoEmpresa")
}

model Empresa {
  id            Int      @id @default(autoincrement())
  nomeFantasia  String
  slug          String   @unique
  tipoEmpresaId Int      @default(1)
  criadoEm      DateTime @default(now())

  tipo          TipoEmpresa    @relation(fields: [tipoEmpresaId], references: [id])
  profissionais Profissional[]
  clientes      Cliente[]
  itensCatalogo ItemCatalogo[]
  transacoes    Transacao[]
  planos          Plano[]
  assinaturas     Assinatura[]
  categoriasCusto CategoriaCusto[]
  fechamentosCaixa FechamentoCaixa[]
  itensTransacao ItemTransacao[]
  creditosAssinatura CreditoAssinatura[]
  agendamentos    Agendamento[]
  ativos          Ativo[]

  @@index([tipoEmpresaId])
  @@map("Empresa")
}

model Profissional {
  id        Int      @id @default(autoincrement())
  empresaId Int      @default(1)
  nome      String
  email     String   @unique
  senha     String
  criadoEm  DateTime @default(now())
  ativo     Boolean  @default(true)
  perfilId  Int      @default(1)

  empresa    Empresa     @relation(fields: [empresaId], references: [id])
  perfil     Perfil      @relation(fields: [perfilId], references: [id])
  transacoes Transacao[]
  agendamentos Agendamento[]

  @@index([perfilId])
  @@index([empresaId])
  @@map("Profissional")
}

model Perfil {
  id            Int            @id @default(autoincrement())
  descricao     String         @unique
  profissionais Profissional[]

  @@map("Perfil")
}

model Cliente {
  id        Int      @id @default(autoincrement())
  empresaId Int      @default(1)
  nome      String
  telefone  String?
  senha     String?
  criadoEm  DateTime @default(now())
  ativo     Boolean  @default(true)

  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  assinaturas Assinatura[]
  transacoes  Transacao[]
  agendamentos Agendamento[]
  ativos      Ativo[]

  @@index([empresaId])
  @@map("Cliente")
}

model ItemCatalogo {
  id         Int      @id @default(autoincrement())
  empresaId  Int      @default(1)
  nome       String
  preco      Decimal  @db.Decimal(10, 2)
  comissao   Decimal? @db.Decimal(5, 2)
  quantidade Int      @default(0)
  ativo      Boolean  @default(true)
  tipoItemId Int

  empresa            Empresa             @relation(fields: [empresaId], references: [id])
  tipo               TipoItem            @relation(fields: [tipoItemId], references: [id])
  creditosAssinatura CreditoAssinatura[]
  itensNoPlano       ItemPlano[]
  itensTransacao     ItemTransacao[]
  itensAgendamento   ServicoAgendamento[]

  @@index([tipoItemId])
  @@index([empresaId])
  @@map("ItemCatalogo")
}

model TipoItem {
  id        Int            @id @default(autoincrement())
  descricao String         @unique
  itens     ItemCatalogo[]

  @@map("TipoItem")
}

model MetodoPagamento {
  id         Int         @id @default(autoincrement())
  descricao  String      @unique
  transacoes Transacao[]

  @@map("MetodoPagamento")
}

model Transacao {
  id               Int      @id @default(autoincrement())
  empresaId        Int      @default(1)
  descricao        String?
  valorTotal       Decimal  @db.Decimal(10, 2)
  data             DateTime @default(now())
  profissionalId   Int?
  clienteId        Int?
  tipoTransacaoId  Int
  formaPagamentoId Int?
  categoriaCustoId Int?

  empresa         Empresa          @relation(fields: [empresaId], references: [id])
  itens           ItemTransacao[]
  cliente         Cliente?         @relation(fields: [clienteId], references: [id])
  profissional    Profissional?    @relation(fields: [profissionalId], references: [id])
  tipo            TipoTransacao    @relation(fields: [tipoTransacaoId], references: [id])
  metodoPagamento MetodoPagamento? @relation(fields: [formaPagamentoId], references: [id])
  categoriaCusto  CategoriaCusto?  @relation(fields: [categoriaCustoId], references: [id])

  @@index([clienteId])
  @@index([profissionalId])
  @@index([tipoTransacaoId])
  @@index([formaPagamentoId])
  @@index([empresaId])
  @@index([categoriaCustoId])
  @@index([empresaId, data])
  @@map("Transacao")
}

model CategoriaCusto {
  id         Int         @id @default(autoincrement())
  empresaId  Int         @default(1)
  descricao  String
  transacoes Transacao[]
  empresa    Empresa     @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@map("CategoriaCusto")
}

model TipoTransacao {
  id         Int         @id @default(autoincrement())
  descricao  String      @unique
  transacoes Transacao[]

  @@map("TipoTransacao")
}

model ItemTransacao {
  id                    Int     @id @default(autoincrement())
  empresaId             Int     @default(1)
  transacaoId           Int
  itemId                Int
  quantidade            Int     @default(1)
  precoUnitario         Decimal @db.Decimal(10, 2)
  usouCreditoAssinatura Boolean @default(false)

  empresa   Empresa      @relation(fields: [empresaId], references: [id])
  item      ItemCatalogo @relation(fields: [itemId], references: [id])
  transacao Transacao    @relation(fields: [transacaoId], references: [id])

  @@index([empresaId])
  @@index([itemId])
  @@index([transacaoId])
  @@map("ItemTransacao")
}

model Plano {
  id          Int            @id @default(autoincrement())
  empresaId   Int            @default(1)
  nome        String
  valorMensal Decimal        @db.Decimal(10, 2)
  ativo       Boolean        @default(true)
  frequencia  FrequenciaPlano @default(MENSAL)

  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  assinaturas Assinatura[]
  itens       ItemPlano[]

  @@index([empresaId])
  @@map("Plano")
}

model ItemPlano {
  id         Int @id @default(autoincrement())
  planoId    Int
  itemId     Int
  quantidade Int

  item  ItemCatalogo @relation(fields: [itemId], references: [id])
  plano Plano        @relation(fields: [planoId], references: [id])

  @@index([itemId])
  @@index([planoId])
  @@map("ItemPlano")
}

model Assinatura {
  id                    Int              @id @default(autoincrement())
  empresaId             Int              @default(1)
  status                statusAssinatura @default(ATIVA)
  diaVencimento         Int?
  dataProximoVencimento DateTime?
  dataUltimoPagamento   DateTime?
  criadoEm              DateTime         @default(now())
  clienteId             Int
  planoId               Int

  empresa  Empresa             @relation(fields: [empresaId], references: [id])
  cliente  Cliente             @relation(fields: [clienteId], references: [id])
  plano    Plano               @relation(fields: [planoId], references: [id])
  creditos CreditoAssinatura[]

  @@index([clienteId])
  @@index([planoId])
  @@index([empresaId])
  @@map("Assinatura")
}

model CreditoAssinatura {
  id                 Int @id @default(autoincrement())
  empresaId          Int @default(1)
  assinaturaId       Int
  itemId             Int
  quantidadeRestante Int

  empresa    Empresa      @relation(fields: [empresaId], references: [id])
  assinatura Assinatura   @relation(fields: [assinaturaId], references: [id])
  item       ItemCatalogo @relation(fields: [itemId], references: [id])

  @@index([empresaId])
  @@index([assinaturaId])
  @@index([itemId])
  @@map("CreditoAssinatura")
}

enum statusAssinatura {
  ATIVA
  INATIVA
}

enum FrequenciaPlano {
  SEMANAL
  QUINZENAL
  MENSAL
}

model FechamentoCaixa {
  id           Int      @id @default(autoincrement())
  empresaId    Int
  data         DateTime @db.Date
  saldoInicial Decimal  @db.Decimal(10, 2)
  receitas     Decimal  @db.Decimal(10, 2) @default(0)
  despesas     Decimal  @db.Decimal(10, 2) @default(0)
  saldoFinal   Decimal  @db.Decimal(10, 2)

  empresa      Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, data])
  @@index([empresaId])
  @@map("FechamentoCaixa")
}

model Agendamento {
  id              Int               @id @default(autoincrement())
  empresaId       Int
  dataHoraInicio  DateTime
  dataHoraFim     DateTime
  clienteId       Int?
  profissionalId  Int
  status          StatusAgendamento @default(CONFIRMADO)
  criadoEm        DateTime          @default(now())
  observacao      String?
  ativoId         Int?

  empresa         Empresa           @relation(fields: [empresaId], references: [id])
  cliente         Cliente?          @relation(fields: [clienteId], references: [id])
  profissional    Profissional      @relation(fields: [profissionalId], references: [id])
  servicos        ServicoAgendamento[]
  ativo           Ativo?            @relation(fields: [ativoId], references: [id])

  @@index([empresaId])
  @@index([clienteId])
  @@index([profissionalId])
  @@index([dataHoraInicio, dataHoraFim])
  @@index([ativoId])
}

model ServicoAgendamento {
  agendamentoId Int
  itemId        Int
  agendamento   Agendamento  @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  item          ItemCatalogo @relation(fields: [itemId], references: [id])

  @@id([agendamentoId, itemId])
  @@index([itemId])
}

enum StatusAgendamento {
  CONFIRMADO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
  NO_SHOW
  INDISPONIVEL
}

model TipoAtivo {
  id                 Int                @id @default(autoincrement())
  chave              String             @unique
  descricao          String
  ativos             Ativo[]
  tipoEmpresasAtivos TipoEmpresaAtivo[]

  @@map("TipoAtivo")
}

model TipoEmpresaAtivo {
  tipoEmpresaId Int
  tipoAtivoId   Int

  tipoEmpresa   TipoEmpresa @relation(fields: [tipoEmpresaId], references: [id])
  tipoAtivo     TipoAtivo   @relation(fields: [tipoAtivoId], references: [id])

  @@id([tipoEmpresaId, tipoAtivoId])
  @@map("TipoEmpresaAtivo")
}

model Ativo {
  id           Int           @id @default(autoincrement())
  empresaId    Int           @default(1)
  clienteId    Int
  tipoAtivoId  Int
  nome         String
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now())

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  tipoAtivo    TipoAtivo     @relation(fields: [tipoAtivoId], references: [id])
  veiculo      AtivoVeiculo?
  animal       AtivoAnimal?
  agendamentos Agendamento[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([tipoAtivoId])
  @@map("Ativo")
}

model AtivoVeiculo {
  ativoId     Int     @id
  modelo      String
  categoriaId Int
  ano         Int?
  cor         String?
  placa       String?

  ativo     Ativo            @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  categoria CategoriaVeiculo @relation(fields: [categoriaId], references: [id])

  @@index([categoriaId])
  @@map("AtivoVeiculo")
}

model AtivoAnimal {
  ativoId   Int     @id
  especieId Int
  raca      String?
  porte     String?

  ativo   Ativo         @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  especie EspecieAnimal @relation(fields: [especieId], references: [id])

  @@index([especieId])
  @@map("AtivoAnimal")
}

model CategoriaVeiculo {
  id        Int    @id @default(autoincrement())
  descricao String @unique

  veiculos AtivoVeiculo[]

  @@map("CategoriaVeiculo")
}

model EspecieAnimal {
  id        Int    @id @default(autoincrement())
  descricao String @unique

  animais AtivoAnimal[]

  @@map("EspecieAnimal")
}


