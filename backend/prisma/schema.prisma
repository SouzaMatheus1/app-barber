generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Profissional {
  id         Int         @id @default(autoincrement())
  nome       String
  email      String      @unique
  senha      String
  criadoEm   DateTime    @default(now())
  ativo      Boolean     @default(true)
  perfilId   Int         @default(1)
  perfil     Perfil      @relation(fields: [perfilId], references: [id])
  transacoes Transacao[]

  @@index([perfilId], map: "Profissional_perfilId_fkey")
}

model Perfil {
  id            Int            @id @default(autoincrement())
  descricao     String         @unique
  profissionais Profissional[]
}

model Cliente {
  id          Int          @id @default(autoincrement())
  nome        String
  telefone    String?
  criadoEm    DateTime     @default(now())
  ativo       Boolean      @default(true)
  assinaturas Assinatura[]
  transacoes  Transacao[]
}

model ItemCatalogo {
  id                 Int                 @id @default(autoincrement())
  nome               String
  preco              Decimal             @db.Decimal(10, 2)
  comissao           Decimal?            @db.Decimal(5, 2)
  quantidade         Int                 @default(0)
  ativo              Boolean             @default(true)
  tipoItemId         Int
  creditosAssinatura CreditoAssinatura[]
  tipo               TipoItem            @relation(fields: [tipoItemId], references: [id])
  itensNoPlano       ItemPlano[]
  itensTransacao     ItemTransacao[]

  @@index([tipoItemId], map: "ItemCatalogo_tipoItemId_fkey")
}

model TipoItem {
  id        Int            @id @default(autoincrement())
  descricao String         @unique
  itens     ItemCatalogo[]
}

model MetodoPagamento {
  id         Int         @id @default(autoincrement())
  descricao  String      @unique
  transacoes Transacao[]
}

model Transacao {
  id               Int              @id @default(autoincrement())
  descricao        String?
  valorTotal       Decimal          @db.Decimal(10, 2)
  data             DateTime         @default(now())
  profissionalId   Int
  clienteId        Int?
  tipoTransacaoId  Int
  formaPagamentoId Int?
  itens            ItemTransacao[]
  cliente          Cliente?         @relation(fields: [clienteId], references: [id])
  profissional     Profissional     @relation(fields: [profissionalId], references: [id])
  tipo             TipoTransacao    @relation(fields: [tipoTransacaoId], references: [id])
  metodoPagamento  MetodoPagamento? @relation(fields: [formaPagamentoId], references: [id])

  @@index([clienteId], map: "Transacao_clienteId_fkey")
  @@index([profissionalId], map: "Transacao_profissionalId_fkey")
  @@index([tipoTransacaoId], map: "Transacao_tipoTransacaoId_fkey")
  @@index([formaPagamentoId], map: "Transacao_formaPagamentoId_fkey")
}

model TipoTransacao {
  id         Int         @id @default(autoincrement())
  descricao  String      @unique
  transacoes Transacao[]
}

model ItemTransacao {
  id                    Int          @id @default(autoincrement())
  transacaoId           Int
  itemId                Int
  quantidade            Int          @default(1)
  precoUnitario         Decimal      @db.Decimal(10, 2)
  usouCreditoAssinatura Boolean      @default(false)
  item                  ItemCatalogo @relation(fields: [itemId], references: [id])
  transacao             Transacao    @relation(fields: [transacaoId], references: [id])

  @@index([itemId], map: "ItemTransacao_itemId_fkey")
  @@index([transacaoId], map: "ItemTransacao_transacaoId_fkey")
}

model Plano {
  id          Int          @id @default(autoincrement())
  nome        String
  valorMensal Decimal      @db.Decimal(10, 2)
  ativo       Boolean      @default(true)
  assinaturas Assinatura[]
  itens       ItemPlano[]
}

model ItemPlano {
  id         Int          @id @default(autoincrement())
  planoId    Int
  itemId     Int
  quantidade Int
  item       ItemCatalogo @relation(fields: [itemId], references: [id])
  plano      Plano        @relation(fields: [planoId], references: [id])

  @@index([itemId], map: "ItemPlano_itemId_fkey")
  @@index([planoId], map: "ItemPlano_planoId_fkey")
}

model Assinatura {
  id            Int                 @id @default(autoincrement())
  status        statusAssinatura    @default(ATIVA)
  diaVencimento Int?
  criadoEm      DateTime            @default(now())
  clienteId     Int
  planoId       Int
  cliente       Cliente             @relation(fields: [clienteId], references: [id])
  plano         Plano               @relation(fields: [planoId], references: [id])
  creditos      CreditoAssinatura[]

  @@index([clienteId], map: "Assinatura_clienteId_fkey")
  @@index([planoId], map: "Assinatura_planoId_fkey")
}

model CreditoAssinatura {
  id                 Int          @id @default(autoincrement())
  assinaturaId       Int
  itemId             Int
  quantidadeRestante Int
  assinatura         Assinatura   @relation(fields: [assinaturaId], references: [id])
  item               ItemCatalogo @relation(fields: [itemId], references: [id])

  @@index([assinaturaId], map: "CreditoAssinatura_assinaturaId_fkey")
  @@index([itemId], map: "CreditoAssinatura_itemId_fkey")
}

enum statusAssinatura {
  ATIVA
  INATIVA
}
