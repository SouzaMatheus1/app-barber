// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Profissional {
  id         Int      @id @default(autoincrement())
  nome       String
  email      String   @unique
  senha      String
  criadoEm   DateTime @default(now())
  
  perfilId   Int      @default(1)
  perfil     Perfil   @relation(fields: [perfilId], references: [id])
  
  transacoes Transacao[]
}

model Perfil {
  id            Int            @id @default(autoincrement())
  descricao     String         @unique // Ex: "ADMIN", "BARBEIRO"
  
  profissionais Profissional[]
}

model Cliente {
  id         Int      @id @default(autoincrement())
  nome       String
  telefone   String?
  criadoEm   DateTime @default(now())
  
  transacoes Transacao[]
}

model ItemCatalogo {
  id         Int             @id @default(autoincrement())
  nome       String
  preco      Decimal         @db.Decimal(10, 2)
  comissao   Decimal?        @db.Decimal(5, 2) // % de comissão
  
  tipoItemId Int
  tipo       TipoItem        @relation(fields: [tipoItemId], references: [id])
  
  itensTransacao ItemTransacao[]
}

model TipoItem {
  id            Int            @id @default(autoincrement())
  descricao     String         @unique // Ex: "SERVICO", "PRODUTO"
  
  itens         ItemCatalogo[]
}

model Transacao {
  id             Int           @id @default(autoincrement())
  descricao      String?
  valorTotal     Decimal       @db.Decimal(10, 2)
  data           DateTime      @default(now())
  
  tipoTransacaoId Int
  tipo            TipoTransacao @relation(fields: [tipoTransacaoId], references: [id])
  
  profissionalId  Int?
  profissional    Profissional? @relation(fields: [profissionalId], references: [id])
  
  clienteId       Int?
  cliente         Cliente?      @relation(fields: [clienteId], references: [id])

  itens          ItemTransacao[]
}

model TipoTransacao {
  id            Int            @id @default(autoincrement())
  descricao     String         @unique // Ex: "ENTRADA", "SAIDA"
  
  transacoes    Transacao[]
}

model ItemTransacao {
  id            Int          @id @default(autoincrement())
  transacaoId   Int
  itemId        Int
  quantidade    Int          @default(1)
  precoUnitario Decimal      @db.Decimal(10, 2) // Preço no momento da venda

  transacao     Transacao    @relation(fields: [transacaoId], references: [id])
  item          ItemCatalogo @relation(fields: [itemId], references: [id])
}